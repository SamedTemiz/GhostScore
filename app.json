{
  "expo": {
    "name": "GhostScore: Profile Insights",
    "slug": "ghostscore",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#13131F"
    },
    "android": {
      "package": "com.ghostscore.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#13131F"
      },
      "privacyPolicyUrl": "https://ghostscore.app/privacy",
      "permissions": [],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ghostscore.app"
    },
    "scheme": "ghostscore",
    "newArchEnabled": true,
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1547168097704291~5427443880"
        }
      ]
    ],
    "extra": {
      "privacyPolicyUrl": "https://ghostscore.app/privacy"
    }
  }
}
