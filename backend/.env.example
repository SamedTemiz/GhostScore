# ── JWT (RS256) ───────────────────────────────────────────────
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"

# ── AES-256-GCM Session Şifreleme ────────────────────────────
# python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
SESSION_ENCRYPTION_KEY="base64_encoded_32_byte_random_key_here"

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."  # service_role key — JWT'den farklı!
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# ── Redis (rate limiting) ─────────────────────────────────────
# Opsiyonel — yoksa in-memory kullanır (tek instance için yeterli)
REDIS_URL="redis://localhost:6379"

# ── CORS ─────────────────────────────────────────────────────
# Virgülle ayrılmış origin listesi
ALLOWED_ORIGINS="https://your-app.com,exp://localhost:8081"

# ── Limitler ─────────────────────────────────────────────────
ANALYSIS_PER_DAY_LIMIT=1
LOGIN_RATE_LIMIT="5/minute"
